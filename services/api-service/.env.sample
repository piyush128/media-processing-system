PORT=3000

# MinIO (S3-compatible Object Storage)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=media-uploads

# CDN (locally points to MinIO, replace with CDN domain in production)
CDN_URL=http://localhost:9000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=media_user
DB_PASSWORD=media_pass
DB_NAME=media_db
